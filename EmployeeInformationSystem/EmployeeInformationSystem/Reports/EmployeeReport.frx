<?xml version="1.0" encoding="utf-8"?>
<Report ScriptLanguage="CSharp" ReportInfo.Created="2026-03-09">
  <Dictionary>
    <TableDataSource Name="Employee" ReferenceName="Employee" DataType="System.Object">
      <Column Name="Id" DataType="System.Int32"/>
      <Column Name="Name" DataType="System.String"/>
      <Column Name="Department" DataType="System.String"/>
      <Column Name="Salary" DataType="System.Double"/>
    </TableDataSource>
  </Dictionary>
  <ReportPage Name="Page1">
    <ReportTitleBand Name="ReportTitle1" Height="30">
      <TextObject Name="Text1" Width="500" Height="30" Text="Employee Report" Font="Arial, 16pt, style=Bold"/>
    </ReportTitleBand>
    <DataBand Name="Data1" DataSource="Employee" Height="20">
      <TextObject Name="TextId" Width="50" Height="20" Left="0" Text="[Employee.Id]"/>
      <TextObject Name="TextName" Width="150" Height="20" Left="50" Text="[Employee.Name]"/>
      <TextObject Name="TextDept" Width="150" Height="20" Left="200" Text="[Employee.Department]"/>
      <TextObject Name="TextSalary" Width="100" Height="20" Left="350" Text="[Employee.Salary]"/>
    </DataBand>
  </ReportPage>
</Report>